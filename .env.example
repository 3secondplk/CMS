# Neon PostgreSQL (Vercel + Neon)
# ───────────────────────────────────────
# 1. Buat project di https://neon.tech
# 2. Copy connection string dari dashboard Neon
# 3. Paste di bawah ini

# Pooled connection (dari Neon dashboard → Pooled connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.region.pooler.neon.tech/dbname?sslmode=require"

# NextAuth
NEXT_AUTH_SECRET="your-secret-key-here"
NEXT_AUTH_URL="https://your-domain.vercel.app"