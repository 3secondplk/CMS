// ─────────────────────────────────────────────────────────
// CMS Crew Management System — Prisma Schema (PostgreSQL / Neon)
// Developer: Ahtjong Labs
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id             String  @id @default(cuid())
  name           String
  logo           String?
  monthlyTarget  Float   @default(0)
  week1Target    Float   @default(0)
  week2Target    Float   @default(0)
  week3Target    Float   @default(0)
  week4Target    Float   @default(0)
  crews          Crew[]
  jobdesks        Jobdesk[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Crew {
  id         String  @id @default(cuid())
  name       String
  photo      String?
  employeeId String  @unique
  groupId    String
  group      Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sales      Sale[]
  jobdesks    Jobdesk[] @relation("CrewJobdesks")
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id               String   @id @default(cuid())
  crewId           String?
  crew             Crew?    @relation(fields: [crewId], references: [id], onDelete: SetNull)
  tanggal          String   @default("1970-01-01")
  idPenjualan      String?
  statusRetention  String?
  retentionCode    String?
  kodeExtend       String   @default("")
  brand            String?
  dept             String?
  modul            String?
  ukuran           String?
  qty              Int      @default(0)
  hjp              Float    @default(0)
  netto            Float    @default(0)
  diskon           Float    @default(0)
  diskonRp         Float    @default(0)
  potongan         Float    @default(0)
  potonganV        Float    @default(0)
  settle           Float    @default(0)
  pembayaran       String?
  program          String?
  channelStock     String?
  claimedAt        DateTime?
  createdAt        DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  crewName    String?
  saleId      String?
  metadata    String?
  createdAt   DateTime @default(now())
}

// ─── Jobdesk / Daily Task Management ──────────────────
model Jobdesk {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String   @default("1970-01-01") // YYYY-MM-DD format
  priority    String   @default("regular") // "regular" or "urgent"
  status      String   @default("pending") // "pending", "in_progress", "completed"
  order       Int      @default(0)         // for drag-and-drop ordering within a date
  groupId     String?                   // assigned Group/Zoning
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  crewId      String?                   // assigned Crew
  crew        Crew?    @relation("CrewJobdesks", fields: [crewId], references: [id], onDelete: SetNull)
  validatedByAdmin Boolean @default(false) // admin validation checkbox
  validatedBy  String?                   // admin who validated
  validatedAt  DateTime?                 // when admin validated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
