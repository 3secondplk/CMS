// ─────────────────────────────────────────────────────────
// CMS Crew Management System — Prisma Schema (PostgreSQL)
// Deploy ke Vercel dengan Neon / Supabase / Railway DB
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id             String  @id @default(cuid())
  name           String
  logo           String?
  monthlyTarget  Float   @default(0)
  week1Target    Float   @default(0)
  week2Target    Float   @default(0)
  week3Target    Float   @default(0)
  week4Target    Float   @default(0)
  week5Target    Float   @default(0)
  tiktokActive   Boolean @default(false)
  crews          Crew[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Crew {
  id          String      @id @default(cuid())
  name        String
  photo       String?
  employeeId  String      @unique
  groupId     String
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sales       Sale[]
  tiktokSales TikTokSale[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Sale {
  id               String    @id @default(cuid())
  crewId           String?
  crew             Crew?     @relation(fields: [crewId], references: [id], onDelete: SetNull)
  tanggal          String
  idPenjualan      String?
  statusRetention  String?
  retentionCode    String?
  kodeExtend       String
  brand            String?
  dept             String?
  modul            String?
  ukuran           String?
  qty              Int       @default(0)
  hjp              Float     @default(0)
  netto            Float     @default(0)
  diskon           Float     @default(0)
  diskonRp         Float     @default(0)
  potongan         Float     @default(0)
  potonganV        Float     @default(0)
  settle           Float     @default(0)
  pembayaran       String?
  program          String?
  channelStock     String?
  claimedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([tanggal])
  @@index([kodeExtend])
  @@index([crewId])
  @@index([program])
  @@index([tanggal, kodeExtend])
  @@index([idPenjualan])
}

model TikTokSale {
  id        String   @id @default(cuid())
  crewId    String?
  crew      Crew?    @relation(fields: [crewId], references: [id], onDelete: SetNull)
  tanggal   String
  idOrder   String
  status    String   @default("Pengiriman")
  artikel   String
  size      String?
  qty       Int      @default(1)
  revenue   Float    @default(0)
  settle    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tanggal])
  @@index([crewId])
  @@index([status])
  @@index([idOrder])
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  crewName    String?
  saleId      String?
  metadata    String?
  createdAt   DateTime @default(now())
}