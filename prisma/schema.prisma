// ─────────────────────────────────────────────────────────
// CMS Crew Management System — Prisma Schema (PostgreSQL)
// Developer: Ahtjong Labs
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String   @default("Admin")
  jobdeskVerifications Jobdesk[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id             String    @id @default(cuid())
  name           String
  logo           String?
  monthlyTarget  Float     @default(0)
  week1Target    Float     @default(0)
  week2Target    Float     @default(0)
  week3Target    Float     @default(0)
  week4Target    Float     @default(0)
  crews          Crew[]
  jobdesks       Jobdesk[]
  jobdeskTemplates JobdeskTemplate[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Crew {
  id         String    @id @default(cuid())
  name       String
  label      String    @default("")
  photo      String?
  employeeId String    @unique
  groupId    String
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sales      Sale[]
  jobdesks   Jobdesk[]
  jobdeskTemplates JobdeskTemplate[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([groupId])
}

model Sale {
  id               String   @id @default(cuid())
  crewId           String?
  crew             Crew?    @relation(fields: [crewId], references: [id], onDelete: SetNull)
  tanggal          String
  idPenjualan      String?
  statusRetention  String?
  retentionCode    String?
  kodeExtend       String
  brand            String?
  dept             String?
  modul            String?
  ukuran           String?
  qty              Int      @default(0)
  hjp              Float    @default(0)
  netto            Float    @default(0)
  diskon           Float    @default(0)
  diskonRp         Float    @default(0)
  potongan         Float    @default(0)
  potonganV        Float    @default(0)
  settle           Float    @default(0)
  pembayaran       String?
  program          String?
  channelStock     String?
  claimedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([tanggal])
  @@index([kodeExtend])
  @@index([crewId])
  @@index([claimedAt])
  @@index([brand])
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  crewName    String?
  saleId      String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ─── Jobdesk / Daily Task Management ─────────────────────

model ShiftSetting {
  id        String   @id @default(cuid())
  shiftName String   @default("Default Shift")
  shiftStart String  @default("08:00")
  shiftEnd   String  @default("17:00")
  timezone   String   @default("Asia/Jakarta")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Jobdesk {
  id                 String    @id @default(cuid())
  groupId            String
  group              Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  crewId             String?
  crew               Crew?     @relation(fields: [crewId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  status             String    @default("pending") // pending, in_progress, completed
  priority           String    @default("medium") // low, medium, high
  verificationPercent Int      @default(0)
  verifiedByAdminId  String?
  verifiedByAdmin    Admin?    @relation(fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  notes              String?
  jobDate            String    // YYYY-MM-DD in WIB (UTC+7)
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([groupId])
  @@index([jobDate])
  @@index([status])
  @@index([crewId])
}

model JobdeskTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("medium") // low, medium, high
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  crewId      String?
  crew        Crew?    @relation(fields: [crewId], references: [id], onDelete: SetNull)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
  @@index([isActive])
}
